{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FileDozer",
  "version": "0.1.0",
  "identifier": "com.filedozer.app",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FileDozer",
        "width": 720,
        "height": 540,
        "minWidth": 500,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}